# Ignore node_modules
node_modules/

# Ignore build files
build/
dist/

# Ignore environment files
.env
.env.*
!.env.example

# Ignore version control
.git
.gitignore

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore editor files
.vscode/
.idea/
*.swp
*.swo

# Ignore logs
*.log
npm-debug.log*

# Ignore package manager files
yarn.lock
package-lock.json

# Ignore Docker files except what we need
Dockerfile
.dockerignore

# Ignore nginx config except what we need
!nginx.conf
